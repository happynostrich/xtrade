# xtrade environment file template — copy to /etc/xtrade/env (mode 0640 root:xtrade).
# Per Phase 4 brief §10. Values below are placeholders; never commit a populated copy.
#
# A6 Bug 6: env-var names must match what the installed venues yamls
# reference (each yaml names its env vars explicitly under `*_env:`).
# See `config/venues.*.yaml` for the source of truth; the cross-check
# test `tests/test_venues_env_crosscheck.py` enforces this contract.

# --- Binance USDT-M futures testnet (REQUIRED — referenced by
# venues.binance_futures.testnet.yaml, which the installer seeds by
# default) ---
BINANCE_FUTURES_TESTNET_API_KEY=
BINANCE_FUTURES_TESTNET_API_SECRET=

# --- Binance SPOT testnet (OPTIONAL — only needed if you also install
# venues.binance_spot.testnet.yaml) ---
BINANCE_SPOT_TESTNET_API_KEY=
BINANCE_SPOT_TESTNET_API_SECRET=

# --- Binance USDT-M futures MAINNET (Phase 6 T1 — REQUIRED only on
# the mainnet host; referenced by venues.binance_futures.mainnet.yaml).
# Mainnet credentials must NEVER be present on a testnet host: keep
# these blank on testnet boxes so a misrouted yaml fails closed at
# load time. ---
XTRADE_MAINNET_BINANCE_FUTURES_API_KEY=
XTRADE_MAINNET_BINANCE_FUTURES_API_SECRET=

# --- Legacy shared Binance testnet keys (OPTIONAL — only consumed by
# the Phase 0 backward-compat loader `load_binance_testnet()`, used as a
# fallback when the per-subaccount keys above are unset). Safe to leave
# blank for fresh deployments. ---
BINANCE_TESTNET_API_KEY=
BINANCE_TESTNET_API_SECRET=

# --- Hyperliquid testnet credentials (REQUIRED — referenced by
# venues.hyperliquid.testnet.yaml) ---
HYPERLIQUID_TESTNET_ACCOUNT_ADDRESS=
HYPERLIQUID_TESTNET_API_WALLET_KEY=
# Optional; leave blank for no vault.
HYPERLIQUID_TESTNET_VAULT_ADDRESS=

# --- openclaw bridge ---
# xtrade -> openclaw POST endpoint
OPENCLAW_GATEWAY=https://openclaw.example.invalid
# Bearer token for xtrade -> openclaw outbound (matches openclaw.json route.secret)
OPENCLAW_SHARED_SECRET=
# Bearer token for openclaw -> xtrade inbound (xtrade-bridge.service)
# Recommended: distinct from OPENCLAW_SHARED_SECRET so a compromise of one
# direction does not authorize the other.
OPENCLAW_INBOUND_SECRET=

# --- Mainnet unlock (Phase 5 third lock; see src/xtrade/live/mainnet_unlock.py) ---
# Currently unused: Phase 5 Lock 1 (_assert_testnet_only) still hard-rejects
# mainnet venues, so Lock 3 is dead code in production. It becomes load-bearing
# in Phase 6 when mainnet tap tests start and Lock 1 is relaxed conditional on
# the unlock ritual. Until then, leave this commented out.
#
# Ritual (Phase 6 onwards):
#   1. Generate a random secret:        token=$(openssl rand -hex 32)
#   2. Set this env var:                XTRADE_MAINNET_UNLOCK_TOKEN=$token
#   3. Write the file as root:          echo "$token" | sudo tee /etc/xtrade/mainnet_unlock
#                                       sudo chown root:root /etc/xtrade/mainnet_unlock
#                                       sudo chmod 0400 /etc/xtrade/mainnet_unlock
# Failure to satisfy any condition raises MainnetUnlockError at startup.
# XTRADE_MAINNET_UNLOCK_TOKEN=

# --- Runtime caches (A6 Bug 3: required for vectorbt/numba under
# ProtectSystem=strict + ProtectHome=yes). The installer appends these
# automatically when seeding the env file from this template; they are
# documented here so operators editing /etc/xtrade/env later know not to
# remove them. ---
# NUMBA_CACHE_DIR=/var/lib/xtrade/numba_cache
# HOME=/var/lib/xtrade

# --- Optional: override default state roots (Phase 4 install script sets these) ---
# XTRADE_SIGNALS_ROOT=/var/lib/xtrade/signals
# XTRADE_APPROVALS_ROOT=/var/lib/xtrade/approvals
# XTRADE_CATALOG_ROOT=/var/lib/xtrade/catalog
# XTRADE_LOGS_ROOT=/var/lib/xtrade/logs

# --- Optional: override the .env file path used by xtrade.config
# (A6 Bug 7). Defaults to the repo root .env for local dev; in VPS
# deployments systemd's EnvironmentFile= populates the process env
# directly, so this is rarely needed in production. ---
# XTRADE_ENV_FILE=/etc/xtrade/env
