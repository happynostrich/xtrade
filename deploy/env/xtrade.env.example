# xtrade environment file template — copy to /etc/xtrade/env (mode 0640 root:xtrade).
# Per Phase 4 brief §10. Values below are placeholders; never commit a populated copy.

# --- Binance testnet credentials (Phase 0/1) ---
BINANCE_TESTNET_API_KEY=
BINANCE_TESTNET_API_SECRET=

# --- Hyperliquid testnet credentials (Phase 0/1) ---
HYPERLIQUID_TESTNET_PRIVATE_KEY=
HYPERLIQUID_TESTNET_WALLET_ADDRESS=

# --- openclaw bridge ---
# xtrade -> openclaw POST endpoint
OPENCLAW_GATEWAY=https://openclaw.example.invalid
# Bearer token for xtrade -> openclaw outbound (matches openclaw.json route.secret)
OPENCLAW_SHARED_SECRET=
# Bearer token for openclaw -> xtrade inbound (xtrade-bridge.service)
# Recommended: distinct from OPENCLAW_SHARED_SECRET so a compromise of one
# direction does not authorize the other.
OPENCLAW_INBOUND_SECRET=

# --- Mainnet unlock (Phase 5 third lock; see src/xtrade/live/mainnet_unlock.py) ---
# Currently unused: Phase 5 Lock 1 (_assert_testnet_only) still hard-rejects
# mainnet venues, so Lock 3 is dead code in production. It becomes load-bearing
# in Phase 6 when mainnet tap tests start and Lock 1 is relaxed conditional on
# the unlock ritual. Until then, leave this commented out.
#
# Ritual (Phase 6 onwards):
#   1. Generate a random secret:        token=$(openssl rand -hex 32)
#   2. Set this env var:                XTRADE_MAINNET_UNLOCK_TOKEN=$token
#   3. Write the file as root:          echo "$token" | sudo tee /etc/xtrade/mainnet_unlock
#                                       sudo chown root:root /etc/xtrade/mainnet_unlock
#                                       sudo chmod 0400 /etc/xtrade/mainnet_unlock
# Failure to satisfy any condition raises MainnetUnlockError at startup.
# XTRADE_MAINNET_UNLOCK_TOKEN=

# --- Optional: override default state roots (Phase 4 install script sets these) ---
# XTRADE_SIGNALS_ROOT=/var/lib/xtrade/signals
# XTRADE_APPROVALS_ROOT=/var/lib/xtrade/approvals
# XTRADE_CATALOG_ROOT=/var/lib/xtrade/catalog
# XTRADE_LOGS_ROOT=/var/lib/xtrade/logs
