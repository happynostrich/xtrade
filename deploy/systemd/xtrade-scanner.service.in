[Unit]
Description=xtrade research scanner (oneshot per timer tick)
Documentation=file://${OPT_XTRADE}/current/docs/phase4_brief.md
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=${XTRADE_USER}
Group=${XTRADE_GROUP}
EnvironmentFile=${ETC_XTRADE}/env
WorkingDirectory=${OPT_XTRADE}/current
ExecStart=${OPT_XTRADE}/.venv/bin/xtrade scan run --universe ${ETC_XTRADE}/universe.yaml --queue-root ${VAR_XTRADE}/signals --catalog ${VAR_XTRADE}/catalog --logs-root ${VAR_XTRADE}/logs
TimeoutStartSec=300s
StandardOutput=journal
StandardError=journal
SyslogIdentifier=xtrade.scanner

MemoryMax=600M
MemorySwapMax=0
CPUQuota=60%
TasksMax=256
OOMScoreAdjust=600

ProtectSystem=strict
ProtectHome=true
PrivateTmp=true
PrivateDevices=true
ProtectKernelTunables=true
ProtectKernelModules=true
ProtectControlGroups=true
NoNewPrivileges=true
ReadWritePaths=${VAR_XTRADE}
CapabilityBoundingSet=
AmbientCapabilities=
RestrictAddressFamilies=AF_INET AF_INET6 AF_UNIX
LockPersonality=true
RestrictRealtime=true
RestrictSUIDSGID=true
